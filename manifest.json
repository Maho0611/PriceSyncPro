{
  "manifest_version": 3,
  "name": "PriceSyncPro - New API 定价同步助手",
  "version": "3.1.0",
  "description": "在 New API 管理后台中，将渠道已有模型与 OpenRouter/LiteLLM 官方价格模糊匹配，一键同步 ModelRatio 和 CompletionRatio 配置",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "cookies",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "PriceSyncPro - 定价同步"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["official_prices.json"],
      "matches": ["<all_urls>"]
    }
  ]
}